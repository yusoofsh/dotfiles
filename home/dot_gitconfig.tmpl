[user]
	name = Yusoof SH
	username = yusoofsh
	signingKey = B46E6981

[color "branch"]
	current = yellow bold reverse
	local = yellow bold
	remote = green bold

[color "diff"]
	meta = yellow bold
	frag = magenta bold
	old = red bold
	new = green bold
	whitespace = red reverse

[color "status"]
	added = green
	changed = yellow
	untracked = cyan

[color]
	ui = auto
	status = auto
	branch = auto
	diff = auto

[core]
	pager = bat
	whitespace = trailing-space
	autocrlf = input
	longpaths = true
	excludesfile = ~/.gitignore
	editor = code --wait
	quotepath = false

[commit]
	gpgSign = true

[credential]
	credentialStore = gpg
	autoDetectTimeout = 500
	guiPrompt = false
	cacheOptions = --timeout 1200
	{{ if eq .chezmoi.os "darwin" }}helper =
	helper = /usr/local/bin/git-credential-manager{{ else if eq .chezmoi.os "linux" }}helper =
	helper = ~/.dotnet/tools/git-credential-manager{{ end }}

[diff]
	mnemonicPrefix = true
	renames = true
	wordRegex = .
	submodule = log

[difftool]
	prompt = false

[fetch]
	recurseSubmodules = on-demand
	prune = true

[filter "lfs"]
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true

[gitflow "branch"]
	master = main
	develop = dev

[gitflow "prefix"]
	feature = feature/
	bugfix = bugfix/
	release = release/
	hotfix = hotfix/
	support = support/
	versiontag = v

[gpg]
	{{ if eq .chezmoi.os "darwin" }}program = /usr/local/bin/gpg{{ else if eq .chezmoi.os "linux" }}program = /usr/bin/gpg{{ end }}

[grep]
	break = true
	heading = true
	lineNumber = true
	extendedRegexp = true

[help]
	autocorrect = 20

[init]
	defaultBranch = main

[log]
	abbrevCommit = true
	follow = true
	decorate = true

[merge]
	tool = code --wait

[mergetool "code"]
	cmd = code --wait --merge $REMOTE $LOCAL $BASE $MERGED

[mergetool]
	keepBackup = true
	keepTemporaries = false
	writeToTemp = true
	prompt = false

[pull]
	ff = only

[push]
	default = matching
	followTags = true
	autoSetupRemote = true

[rebase]
	autosquash = true
	updateRefs = true

[status]
	submoduleSummary = true
	showUntrackedFiles = all

[tag]
	sort = version:refname

[includeIf "gitdir:~/Documents/Division/Open/Code/yusoofsh/"]
	path = ~/Documents/Division/Open/Code/yusoofsh/.gitconfig

[includeIf "gitdir:~/Documents/Division/Office/CloudThought/"]
	path = ~/Documents/Division/Office/CloudThought/.gitconfig

[credential "https://dev.azure.com"]
	useHttpPath = true
